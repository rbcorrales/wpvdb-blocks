#!/bin/sh
set -eu

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
js_files="$(printf '%s\n' "$staged_files" | grep -E '^(src/.*\.(js|jsx)|scripts/.*\.m?js)$' || true)"
scss_files="$(printf '%s\n' "$staged_files" | grep -E '^src/.*\.scss$' || true)"

if printf '%s\n' "$staged_files" | grep -E '\.php$' >/dev/null 2>&1; then
	echo "Running PHP lint on staged files..."
	./vendor/bin/phpcs --filter=GitStaged
else
	echo "No staged PHP files to lint."
fi

if [ -n "$js_files" ]; then
	echo "Running JavaScript lint on staged files..."
	bun run lint:js:staged -- $js_files
else
	echo "No staged JavaScript files to lint."
fi

if [ -n "$scss_files" ]; then
	echo "Running SCSS lint on staged files..."
	bun run lint:scss:staged -- $scss_files
else
	echo "No staged SCSS files to lint."
fi

echo "Running static analysis..."
composer analyze
